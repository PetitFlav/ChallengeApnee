generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Challenge {
  id                   String          @id @default(cuid())
  name                 String
  eventDate            DateTime
  durationMinutes      Int             @default(120)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  startTime            String?
  endTime              String?
  roundsCount          Int             @default(4)
  lanes25Count         Int             @default(4)
  lanes50Count         Int             @default(6)
  isActive             Boolean         @default(false)
  isArchived           Boolean         @default(false)
  timezone             String          @default("Europe/Paris")
  closedAt             DateTime?
  clubOrganisateur     String          @default("")
  clubOrganisateurLogo String?
  clubLinks            ChallengeClub[]
  userLinks            ChallengeUser[]
  finalResults         FinalResult[]
  lanes                Lane[]
  rounds               Round[]
  sheets               Sheet[]
  swimmers             Swimmer[]

  @@map("challenges")
}

model User {
  id                    String          @id @default(cuid())
  firstName             String
  lastName              String
  email                 String          @unique
  passwordHash          String
  isSuperUser           Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  challenges            ChallengeUser[]
  validatedFinalResults FinalResult[]   @relation("FinalResultValidatedBy")
  verifications         Verification[]

  @@map("users")
}

model ChallengeUser {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  createdAt   DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@map("challenge_users")
}

model Club {
  id           String          @id @default(cuid())
  name         String          @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  challenges   ChallengeClub[]
  finalResults FinalResult[]
  swimmers     Swimmer[]

  @@map("clubs")
}

model ChallengeClub {
  id          String    @id @default(cuid())
  challengeId String
  clubId      String
  createdAt   DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([challengeId, clubId])
  @@index([challengeId])
  @@index([clubId])
  @@map("challenge_clubs")
}

model Section {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  finalResults FinalResult[]
  swimmers     Swimmer[]

  @@map("sections")
}

model Swimmer {
  id                String             @id @default(cuid())
  challengeId       String
  number            Int
  firstName         String
  lastName          String
  email             String?
  clubId            String?
  sectionId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  finalResults      FinalResult[]
  entries           SheetEntry[]
  challenge         Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  club              Club?              @relation(fields: [clubId], references: [id])
  section           Section?           @relation(fields: [sectionId], references: [id])
  verificationLines VerificationLine[]

  @@unique([challengeId, number])
  @@index([challengeId, number])
  @@index([lastName])
  @@index([firstName])
  @@index([clubId])
  @@index([sectionId])
  @@map("swimmers")
}

model Lane {
  id           String        @id @default(cuid())
  challengeId  String
  code         String
  distanceM    Int
  displayOrder Int
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  finalResults FinalResult[]
  challenge    Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  sheets       Sheet[]

  @@unique([challengeId, code])
  @@index([challengeId, displayOrder])
  @@map("lanes")
}

model Round {
  id            String        @id @default(cuid())
  challengeId   String
  roundNumber   Int
  label         String
  scheduledTime String?
  displayOrder  Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  finalResults  FinalResult[]
  challenge     Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  sheets        Sheet[]

  @@unique([challengeId, roundNumber])
  @@index([challengeId, displayOrder])
  @@map("rounds")
}

model Sheet {
  id            String         @id @default(cuid())
  challengeId   String
  roundId       String
  laneId        String
  status        SheetStatus    @default(DRAFT)
  enteredBy     String?
  validatedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  finalResults  FinalResult[]
  entries       SheetEntry[]
  challenge     Challenge      @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  lane          Lane           @relation(fields: [laneId], references: [id])
  round         Round          @relation(fields: [roundId], references: [id])
  verifications Verification[]

  @@unique([challengeId, roundId, laneId])
  @@index([challengeId, status])
  @@index([roundId])
  @@index([laneId])
  @@map("sheets")
}

model Verification {
  id           String             @id @default(cuid())
  sheetId      String
  userId       String
  createdAt    DateTime           @default(now())
  finalResults FinalResult[]
  lines        VerificationLine[]
  sheet        Sheet              @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id])

  @@unique([sheetId, userId])
  @@index([sheetId, createdAt])
  @@index([userId])
  @@map("verifications")
}

model VerificationLine {
  id             String        @id @default(cuid())
  verificationId String
  swimmerId      String
  squares        Int
  ticks          Int
  totalLengths   Int
  distanceM      Int
  createdAt      DateTime      @default(now())
  finalResults   FinalResult[]
  swimmer        Swimmer       @relation(fields: [swimmerId], references: [id])
  verification   Verification  @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([swimmerId])
  @@index([verificationId, swimmerId])
  @@map("verification_lines")
}

model SheetEntry {
  id           String        @id @default(cuid())
  sheetId      String
  swimmerId    String
  squares      Int
  ticks        Int
  totalLengths Int
  distanceM    Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  finalResults FinalResult[]
  sheet        Sheet         @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  swimmer      Swimmer       @relation(fields: [swimmerId], references: [id])

  @@index([sheetId])
  @@index([swimmerId])
  @@index([sheetId, swimmerId])
  @@map("sheet_entries")
}

model FinalResult {
  id                       String            @id @default(cuid())
  challengeId              String
  roundId                  String
  laneId                   String
  sheetId                  String
  swimmerId                String
  clubId                   String?
  sectionId                String?
  source                   FinalResultSource
  sourceVerificationId     String?
  sourceVerificationLineId String?
  sourceSheetEntryId       String?
  squares                  Int
  ticks                    Int
  totalLengths             Int
  distanceM                Int
  validatedByUserId        String
  validatedAt              DateTime          @default(now())
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  challenge                Challenge         @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  club                     Club?             @relation(fields: [clubId], references: [id])
  lane                     Lane              @relation(fields: [laneId], references: [id], onDelete: Cascade)
  round                    Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  section                  Section?          @relation(fields: [sectionId], references: [id])
  sheet                    Sheet             @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  sourceSheetEntry         SheetEntry?       @relation(fields: [sourceSheetEntryId], references: [id])
  sourceVerification       Verification?     @relation(fields: [sourceVerificationId], references: [id])
  sourceVerificationLine   VerificationLine? @relation(fields: [sourceVerificationLineId], references: [id])
  swimmer                  Swimmer           @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  validatedBy              User              @relation("FinalResultValidatedBy", fields: [validatedByUserId], references: [id])

  @@unique([challengeId, roundId, laneId, swimmerId])
  @@index([challengeId, validatedAt])
  @@index([sheetId])
  @@index([swimmerId])
  @@index([validatedByUserId])
  @@map("final_results")
}

enum SheetStatus {
  DRAFT
  VALIDATED
}

enum FinalResultSource {
  original
  verification
  manual
}
