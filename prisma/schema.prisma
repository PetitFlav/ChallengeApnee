generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Challenge {
  id              String          @id @default(cuid())
  name            String
  eventDate       DateTime
  durationMinutes Int             @default(120)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  startTime       String?
  timezone        String          @default("Europe/Paris")
  endTime         String?
  roundsCount     Int             @default(4)
  lanes25Count    Int             @default(4)
  lanes50Count    Int             @default(6)
  isActive        Boolean         @default(false)
  isArchived      Boolean         @default(false)
  closedAt        DateTime?
  clubLinks       ChallengeClub[]
  lanes           Lane[]
  rounds          Round[]
  sheets          Sheet[]
  swimmers        Swimmer[]
  userLinks       ChallengeUser[]

  @@map("challenges")
}

model User {
  id           String          @id @default(cuid())
  firstName    String
  lastName     String
  email        String          @unique
  passwordHash String
  isSuperUser  Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  challenges   ChallengeUser[]
  verifications Verification[]

  @@map("users")
}

model ChallengeUser {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@map("challenge_users")
}

model Club {
  id         String          @id @default(cuid())
  name       String          @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  challenges ChallengeClub[]
  swimmers   Swimmer[]

  @@map("clubs")
}

model ChallengeClub {
  id          String    @id @default(cuid())
  challengeId String
  clubId      String
  isHostClub  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([challengeId, clubId])
  @@index([challengeId])
  @@index([clubId])
  @@map("challenge_clubs")
}

model Section {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  swimmers  Swimmer[]

  @@map("sections")
}

model Swimmer {
  id          String       @id @default(cuid())
  challengeId String
  number      Int
  firstName   String
  lastName    String
  email       String
  clubId      String?
  sectionId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  entries     SheetEntry[]
  verificationLines VerificationLine[]
  challenge   Challenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  club        Club?        @relation(fields: [clubId], references: [id])
  section     Section?     @relation(fields: [sectionId], references: [id])

  @@unique([challengeId, number])
  @@index([challengeId, number])
  @@index([lastName])
  @@index([firstName])
  @@index([clubId])
  @@index([sectionId])
  @@map("swimmers")
}

model Lane {
  id           String    @id @default(cuid())
  challengeId  String
  code         String
  distanceM    Int
  displayOrder Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  sheets       Sheet[]

  @@unique([challengeId, code])
  @@index([challengeId, displayOrder])
  @@map("lanes")
}

model Round {
  id            String    @id @default(cuid())
  challengeId   String
  roundNumber   Int
  label         String
  scheduledTime String?
  displayOrder  Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  sheets        Sheet[]

  @@unique([challengeId, roundNumber])
  @@index([challengeId, displayOrder])
  @@map("rounds")
}

model Sheet {
  id          String       @id @default(cuid())
  challengeId String
  roundId     String
  laneId      String
  status      SheetStatus  @default(DRAFT)
  enteredBy   String?
  validatedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  entries     SheetEntry[]
  verifications Verification[]
  challenge   Challenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  lane        Lane         @relation(fields: [laneId], references: [id])
  round       Round        @relation(fields: [roundId], references: [id])

  @@unique([challengeId, roundId, laneId])
  @@index([challengeId, status])
  @@index([roundId])
  @@index([laneId])
  @@map("sheets")
}

model Verification {
  id        String             @id @default(cuid())
  sheetId    String
  userId     String
  createdAt  DateTime          @default(now())
  lines      VerificationLine[]
  sheet      Sheet             @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])

  @@index([sheetId, createdAt])
  @@index([userId])
  @@map("verifications")
}

model VerificationLine {
  id             String       @id @default(cuid())
  verificationId String
  swimmerId      String
  squares        Int
  ticks          Int
  totalLengths   Int
  distanceM      Int
  createdAt      DateTime     @default(now())
  verification   Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  swimmer        Swimmer      @relation(fields: [swimmerId], references: [id])

  @@index([verificationId])
  @@index([swimmerId])
  @@index([verificationId, swimmerId])
  @@map("verification_lines")
}

model SheetEntry {
  id           String   @id @default(cuid())
  sheetId      String
  swimmerId    String
  squares      Int
  ticks        Int
  totalLengths Int
  distanceM    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sheet        Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  swimmer      Swimmer  @relation(fields: [swimmerId], references: [id])

  @@index([sheetId])
  @@index([swimmerId])
  @@index([sheetId, swimmerId])
  @@map("sheet_entries")
}

enum SheetStatus {
  DRAFT
  VALIDATED
}
